<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Green Header -->
        <TextView
            android:id="@+id/submission_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/green"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:padding="10dp"
            android:textStyle="bold"
            android:text="Item Submission"/>

        <!-- Title / message -->
        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/green"
            android:layout_marginTop="40dp"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:text="Item not found"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center"/>

        <!-- Instruction / help text -->
        <TextView
            android:id="@+id/instruction_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item not found in OpenFoodFacts. Please enter item information and description of packaging to get recycling information!"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:layout_gravity="center"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"/>

        <!-- Content card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:padding="16dp"
            android:orientation="vertical"
            android:background="@color/shade">

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/light_grey"
                android:layout_marginBottom="16dp"/>

            <!-- Barcode field -->
            <EditText
                android:id="@+id/barcode_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Barcode"
                android:layout_marginBottom="12dp"
                android:inputType="number"
                android:enabled="false"
            />

            <!-- Manual entry form -->
            <EditText
                android:id="@+id/item_name_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Item Name"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/brand_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Brand"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/description_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Description of Package"
                android:layout_marginBottom="20dp"
                android:minLines="3"
                android:gravity="top"
                android:inputType="textMultiLine"/>

            <Button
                android:id="@+id/submit_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Submit Item"
                app:backgroundTint="@color/green"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>