<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Green Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/green"
            android:text="Submit New Item"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:padding="12dp"/>

        <!-- Card Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:padding="16dp"
            android:orientation="vertical"
            android:background="@color/shade">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose an option below:"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/light_grey"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/assignProductButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Assign Product"
                android:background="@color/green"
                app:backgroundTint="@color/green"/>

            <Button
                android:id="@+id/searchDatabaseButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Search Database"
                android:layout_marginTop="12dp"
                android:background="@color/green"
                app:backgroundTint="@color/green"/>

            <Button
                android:id="@+id/submitPhotoButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Submit Photo"
                android:layout_marginTop="12dp"
                android:background="@color/green"
                app:backgroundTint="@color/green"/>

            <Button
                android:id="@+id/askTeamButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ask Team"
                android:layout_marginTop="12dp"
                android:background="@color/green"
                app:backgroundTint="@color/green"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>